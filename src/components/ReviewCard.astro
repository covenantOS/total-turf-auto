---
// Source-aware review card. Renders the Facebook or Google logo based on
// `review.source`, so Facebook and Google reviews can sit side by side.
interface Review {
  name: string;
  date: string;
  avatar: string;
  source: 'facebook' | 'google';
  rating: number;
  text: string;
}
interface Props {
  review: Review;
}
const { review } = Astro.props;
const stars = Array.from({ length: review.rating });
---
<article class="review reveal">
  <span
    class="review-source"
    aria-label={review.source === 'facebook' ? 'Review from Facebook' : 'Review from Google'}
  >
    {review.source === 'facebook' ? (
      <svg viewBox="0 0 24 24" fill="#1877F2" role="img">
        <path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.4v7A10 10 0 0 0 22 12z"/>
      </svg>
    ) : (
      <svg viewBox="0 0 24 24" role="img">
        <path fill="#4285F4" d="M23 12.3c0-.8-.1-1.6-.2-2.3H12v4.5h6.2c-.3 1.4-1.1 2.6-2.3 3.4v2.8h3.7C21.7 18.8 23 15.8 23 12.3z"/>
        <path fill="#34A853" d="M12 24c3.1 0 5.7-1 7.6-2.8l-3.7-2.8c-1 .7-2.3 1.1-3.9 1.1-3 0-5.5-2-6.4-4.7H1.8v2.9C3.7 21.4 7.6 24 12 24z"/>
        <path fill="#FBBC05" d="M5.6 14.8c-.2-.7-.4-1.4-.4-2.3s.1-1.6.4-2.3V7.3H1.8C1 8.9.6 10.4.6 12.5s.4 3.6 1.2 5.2l3.8-2.9z"/>
        <path fill="#EA4335" d="M12 5.4c1.7 0 3.2.6 4.4 1.7l3.3-3.3C17.7 1.9 15.1.8 12 .8 7.6.8 3.7 3.4 1.8 7.3l3.8 2.9C6.5 7.5 9 5.4 12 5.4z"/>
      </svg>
    )}
  </span>
  <div class="stars" aria-label={`${review.rating} out of 5 stars`}>
    {stars.map(() => (
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3 7h7l-5.5 4 2 7L12 17l-6.5 3 2-7L2 9h7z"/></svg>
    ))}
  </div>
  <p>{review.text}</p>
  <div class="review-author">
    <img
      class="review-avatar"
      src={`/assets/img/reviews/${review.avatar}`}
      alt={`${review.name} profile photo`}
      width="44"
      height="44"
      loading="lazy"
    />
    <span>
      <strong>{review.name}</strong>
      <span class="review-date">{review.date}</span>
    </span>
  </div>
</article>

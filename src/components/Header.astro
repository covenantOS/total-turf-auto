---
interface Props {
  active?: 'home' | 'services' | 'about' | 'contact';
}
const { active } = Astro.props;
---
<header class="header">
  <div class="container">
    <a href="/" class="brand" aria-label="Total Turf & Auto home">
      <img src="/assets/img/logo.jpg" alt="Total Turf & Auto logo" width="56" height="56" />
      <span class="brand-text">
        <strong>Total Turf &amp; Auto</strong>
        <span>Automotive &amp; Diesel Repair</span>
      </span>
    </a>
    <nav class="nav" aria-label="Primary">
      <a href="/" class={active === 'home' ? 'active' : ''}>Home</a>
      <a href="/services" class={active === 'services' ? 'active' : ''}>Services</a>
      <a href="/about" class={active === 'about' ? 'active' : ''}>About</a>
      <a href="/contact" class={active === 'contact' ? 'active' : ''}>Contact</a>
      <a href="/contact#book" class="btn btn--primary">Book Appointment</a>
    </nav>
    <div class="header-actions">
      <a href="tel:+17859254040" class="header-phone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3 19.5 19.5 0 01-6-6 19.8 19.8 0 01-3-8.7A2 2 0 014.1 2h3a2 2 0 012 1.7c.1 1 .4 1.9.7 2.8a2 2 0 01-.5 2.1L8.1 9.9a16 16 0 006 6l1.3-1.3a2 2 0 012.1-.4c.9.3 1.8.6 2.8.7a2 2 0 011.7 2z"/></svg>
        <span><small>Call or text</small><strong>(785) 925-4040</strong></span>
      </a>
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false"><span></span></button>
    </div>
  </div>
</header>

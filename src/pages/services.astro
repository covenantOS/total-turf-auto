---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do I schedule an appointment?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Call or text us at (785) 925-4040, or fill out the appointment request form on our website. We will follow up to confirm a time that works for you.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you work on diesel trucks?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Total Turf & Auto handles diesel diagnostics, maintenance and repairs alongside our automotive services.',
      },
    },
    {
      '@type': 'Question',
      name: 'Will you tell me what is wrong before doing the work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Always. We inspect your vehicle, explain what we find, and review the cost with you before any repair begins. No surprises.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where are you located?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We are located at 2700 NW Topeka Blvd, Topeka, KS 66617, open Monday through Friday from 8:00 AM to 5:00 PM.',
      },
    },
  ],
};
---
<BaseLayout
  title="Auto & Diesel Repair Services in Topeka, KS | Total Turf & Auto"
  description="Auto and diesel repair services in Topeka, KS: routine maintenance, oil changes, brakes, tires, engine repair & replacement, diagnostics and vehicle inspections. Call (785) 925-4040."
  active="services"
>
  <script type="application/ld+json" slot="schema" set:html={JSON.stringify(faqSchema)} />

  <!-- ===== Page hero ===== -->
  <section class="page-hero">
    <div class="container">
      <p class="crumbs"><a href="/">Home</a> / <span>Services</span></p>
      <h1>Auto &amp; Diesel Repair Services</h1>
      <p>Everything your vehicle needs under one roof, backed by honest inspections and quality workmanship.</p>
    </div>
  </section>

  <!-- ===== Service details ===== -->
  <section class="section">
    <div class="container">

      <article class="svc-detail reveal" id="maintenance">
        <img class="svc-detail-media" src="/assets/img/work/oil-change.webp" alt="Oil and filter change supplies staged at Total Turf & Auto in Topeka, KS" width="600" height="700" loading="lazy" />
        <div class="svc-detail-body">
          <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 13h2l2-5h10l2 5h2M5 13v5h2M17 13v5h2M7 18h10"/><circle cx="8" cy="13" r="1"/></svg></div>
          <h3>Routine Maintenance</h3>
          <p>Staying on top of regular service is the cheapest repair you will ever make. We handle the everyday upkeep that keeps small problems from becoming big ones.</p>
          <ul>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Oil &amp; filter changes</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Fluid checks &amp; flushes</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Tune-ups &amp; filters</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Factory-scheduled service</li>
          </ul>
        </div>
      </article>

      <article class="svc-detail reveal" id="diesel">
        <img class="svc-detail-media" src="/assets/img/work/engine-timing.webp" alt="Diesel engine work in progress at Total Turf & Auto" width="600" height="700" loading="lazy" />
        <div class="svc-detail-body">
          <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a4 4 0 00-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 005.4-5.4l-2.8 2.8-2.6-.7-.7-2.6z"/></svg></div>
          <h3>Diesel Repair</h3>
          <p>Diesel engines are built to work hard, and they need a technician who knows them. We diagnose, maintain and repair diesel trucks to keep them dependable for the long haul.</p>
          <ul>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Diesel diagnostics</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Preventive maintenance</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Performance &amp; reliability repairs</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Fluids, filters &amp; service</li>
          </ul>
        </div>
      </article>

      <article class="svc-detail reveal" id="brakes">
        <img class="svc-detail-media" src="/assets/img/work/minivan-lift.webp" alt="Vehicle raised on a lift for brake and tire service at Total Turf & Auto" width="600" height="700" loading="lazy" />
        <div class="svc-detail-body">
          <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/></svg></div>
          <h3>Brakes &amp; Tires</h3>
          <p>Your brakes and tires are the difference between a close call and a safe stop. We keep both in top shape so you drive with confidence.</p>
          <ul>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Brake pads &amp; rotors</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Brake inspections</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Tire rotation &amp; balancing</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Wheel alignment checks</li>
          </ul>
        </div>
      </article>

      <article class="svc-detail reveal" id="engine">
        <img class="svc-detail-media" src="/assets/img/work/truck-engine-hoist.webp" alt="Truck engine on a hoist during a replacement at Total Turf & Auto" width="600" height="700" loading="lazy" />
        <div class="svc-detail-body">
          <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3v4M15 3v4M5 7h14v5a7 7 0 01-14 0z"/><path d="M9 21h6"/></svg></div>
          <h3>Engine Service &amp; Replacement</h3>
          <p>From a stubborn check-engine light to a full engine replacement, we handle the work that keeps your vehicle on the road, or brings it back to life.</p>
          <ul>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Check-engine diagnostics</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Engine repairs</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Complete engine replacement</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Cooling &amp; performance issues</li>
          </ul>
        </div>
      </article>

      <article class="svc-detail reveal" id="inspections">
        <img class="svc-detail-media" src="/assets/img/work/classic-corvette-lift.webp" alt="Vehicle on a lift for a full inspection at Total Turf & Auto in Topeka" width="600" height="700" loading="lazy" />
        <div class="svc-detail-body">
          <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg></div>
          <h3>Vehicle Inspections</h3>
          <p>A good technician knows to check certain things. We give your vehicle a careful, top-to-bottom look so issues get caught early, before they cost you down the road.</p>
          <ul>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Multi-point inspections</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Pre-purchase inspections</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Honest, clear recommendations</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Priorities explained up front</li>
          </ul>
        </div>
      </article>

      <article class="svc-detail reveal" id="diagnostics">
        <img class="svc-detail-media" src="/assets/img/work/interior-wiring.webp" alt="Electrical and wiring diagnostics work at Total Turf & Auto" width="600" height="700" loading="lazy" />
        <div class="svc-detail-body">
          <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12h4l2-7 4 14 3-9 2 4h5"/></svg></div>
          <h3>Diagnostics &amp; Electrical</h3>
          <p>Warning lights and electrical gremlins can be frustrating. We track down the real cause instead of guessing, so the fix actually sticks.</p>
          <ul>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Computer diagnostics</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Battery, starting &amp; charging</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Warning light troubleshooting</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Electrical repairs</li>
          </ul>
        </div>
      </article>

      <p style="text-align:center;color:var(--muted);margin-top:14px;">Don't see your specific repair listed? <a href="tel:+17859254040" style="color:var(--green-dark);font-weight:600;">Give us a call</a>. Chances are we can help.</p>

    </div>
  </section>

  <!-- ===== CTA banner ===== -->
  <section class="section section--soft">
    <div class="container">
      <div class="cta-banner reveal">
        <div>
          <h2>Need One of These Services?</h2>
          <p>Call or text us and we will get your vehicle scheduled right away.</p>
        </div>
        <div class="cta-banner-actions">
          <a href="tel:+17859254040" class="btn btn--white btn--lg">(785) 925-4040</a>
          <a href="/contact#book" class="btn btn--lime btn--lg">Request Appointment</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Good to Know</span>
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="faq-list">
        <div class="faq-item reveal">
          <button class="faq-q" aria-expanded="false">How do I schedule an appointment?
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg></button>
          <div class="faq-a"><p>Call or text us at (785) 925-4040, or fill out the appointment request form on our Contact page. We will follow up to confirm a time that works for you.</p></div>
        </div>
        <div class="faq-item reveal">
          <button class="faq-q" aria-expanded="false">Do you work on diesel trucks?
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg></button>
          <div class="faq-a"><p>Yes. Diesel work is a core part of what we do: diagnostics, maintenance and repairs for diesel trucks, right alongside our automotive services.</p></div>
        </div>
        <div class="faq-item reveal">
          <button class="faq-q" aria-expanded="false">Will you tell me what's wrong before doing the work?
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg></button>
          <div class="faq-a"><p>Always. We inspect your vehicle, explain what we find, and go over the cost with you before any repair begins. No surprises, just honest answers.</p></div>
        </div>
        <div class="faq-item reveal">
          <button class="faq-q" aria-expanded="false">Where are you located and when are you open?
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg></button>
          <div class="faq-a"><p>We are at 2700 NW Topeka Blvd, Topeka, KS 66617, open Monday through Friday from 8:00 AM to 5:00 PM.</p></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

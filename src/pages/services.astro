---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services } from '../data/services.js';

// Inline SVG per service slug so each hub card matches its detail page.
const icons = {
  'routine-maintenance': '<path d="M3 13h2l2-5h10l2 5h2M5 13v5h2M17 13v5h2M7 18h10"/><circle cx="8" cy="13" r="1"/>',
  'diesel-repair': '<path d="M14.7 6.3a4 4 0 00-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 005.4-5.4l-2.8 2.8-2.6-.7-.7-2.6z"/>',
  'brakes-and-tires': '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3"/>',
  'engine-service': '<path d="M9 3v4M15 3v4M5 7h14v5a7 7 0 01-14 0z"/><path d="M9 21h6"/>',
  'vehicle-inspections': '<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>',
  'diagnostics-electrical': '<path d="M2 12h4l2-7 4 14 3-9 2 4h5"/>',
};
---
<BaseLayout
  title="Auto & Diesel Repair Services in Topeka, KS | Total Turf & Auto"
  description="Auto and diesel repair services in Topeka, KS: routine maintenance, oil changes, brakes, tires, engine repair & replacement, diagnostics and vehicle inspections. Call (785) 925-4040."
  active="services"
>
  <!-- ===== Page hero ===== -->
  <section class="page-hero">
    <div class="container">
      <p class="crumbs"><a href="/">Home</a> / <span>Services</span></p>
      <h1>Auto &amp; Diesel Repair Services</h1>
      <p>Everything your vehicle needs under one roof, backed by honest inspections and quality workmanship.</p>
    </div>
  </section>

  <!-- ===== Service cards ===== -->
  <section class="section">
    <div class="container">
      <div class="svc-grid">
        {services.map((s) => (
          <a class="svc-card reveal" href={`/services/${s.slug}/`}>
            <div class="svc-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={icons[s.slug]} />
            </div>
            <h3>{s.name}</h3>
            <p>{s.intro.split('. ')[0]}.</p>
            <span class="svc-link">
              Learn more
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
      <p style="text-align:center;color:var(--muted);margin-top:34px;">Don't see your specific repair listed? <a href="tel:+17859254040" style="color:var(--green-dark);font-weight:600;">Give us a call</a>. Chances are we can help.</p>
    </div>
  </section>

  <!-- ===== CTA banner ===== -->
  <section class="section section--soft">
    <div class="container">
      <div class="cta-banner reveal">
        <div>
          <h2>Need One of These Services?</h2>
          <p>Call or text us and we will get your vehicle scheduled right away.</p>
        </div>
        <div class="cta-banner-actions">
          <a href="tel:+17859254040" class="btn btn--white btn--lg">(785) 925-4040</a>
          <a href="/contact#book" class="btn btn--lime btn--lg">Request Appointment</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

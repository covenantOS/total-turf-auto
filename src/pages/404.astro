>
  <section class="errorpage">
    <div class="container">
      <div class="code">404</div>
      <h1>This Page Took a Wrong Turn</h1>
      <p>The page you are looking for is not here. Let's get you back on the road.</p>
      <div class="hero-cta">
        <a href="/" class="btn btn--primary btn--lg">Back to Home</a>
        <a href="tel:+17859254040" class="btn btn--ghost btn--lg">Call (785) 925-4040</a>
      </div>
    </div>
  </section>
</BaseLayout>
